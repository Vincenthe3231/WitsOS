{
  "name": "@colbymchenry/codegraph",
  "version": "1.1.1",
  "description": "Supercharge AI coding agents with semantic code intelligence â€” surgical context, fewer tool calls, faster answers. 100% local.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@11.0.8",
  "bin": {
    "witsos": "./dist/bin/codegraph.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets && node -e \"require('fs').chmodSync('dist/bin/codegraph.js', 0o755)\"",
    "build:fast": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/db',{recursive:true});fs.copyFileSync('src/db/schema.sql','dist/db/schema.sql');fs.mkdirSync('dist/extraction/wasm',{recursive:true});fs.readdirSync('src/extraction/wasm').filter(f=>f.endsWith('.wasm')).forEach(f=>fs.copyFileSync('src/extraction/wasm/'+f,'dist/extraction/wasm/'+f))\"",
    "preuninstall": "node dist/bin/uninstall.js",
    "copy-assets": "node -e \"const fs=require('fs');fs.mkdirSync('dist/db',{recursive:true});fs.copyFileSync('src/db/schema.sql','dist/db/schema.sql');fs.mkdirSync('dist/extraction/wasm',{recursive:true});fs.readdirSync('src/extraction/wasm').filter(f=>f.endsWith('.wasm')).forEach(f=>fs.copyFileSync('src/extraction/wasm/'+f,'dist/extraction/wasm/'+f))\"",
    "dev": "tsc --watch",
    "cli": "npm run build && node dist/bin/codegraph.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:eval": "vitest run __tests__/evaluation/",
    "eval": "npm run build && npx tsx __tests__/evaluation/runner.ts",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "reset": "node -e \"const fs=require('fs');fs.rmSync('node_modules',{recursive:true,force:true});fs.rmSync('pnpm-lock.yaml',{force:true})\" && pnpm install"
  },
  "keywords": [
    "code-intelligence",
    "knowledge-graph",
    "static-analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@colbymchenry/codegraph": "link:",
    "adm-zip": "^0.5.17",
    "commander": "^14.0.2",
    "fast-string-width": "^3.0.2",
    "fast-wrap-ansi": "^0.2.0",
    "ffmpeg-ffprobe-static": "6.1.2-rc.1",
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "pdf-parse": "^1.1.4",
    "picomatch": "^4.0.3",
    "sherpa-onnx": "^1.13.3",
    "sisteransi": "^1.0.5",
    "tree-sitter-wasms": "^0.1.11",
    "web-tree-sitter": "^0.25.3"
  },
  "devDependencies": {
    "@gutenye/ocr-models": "^1.4.2",
    "@gutenye/ocr-node": "^1.4.8",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.19.30",
    "@types/pdf-parse": "^1.1.5",
    "@types/picomatch": "^4.0.2",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  },
  "volta": {
    "node": "22.23.1",
    "pnpm": "11.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node"
    ]
  }
}